---
interface Props {
  compact?: boolean;
  showEmail?: boolean;
  submitLabel?: string;
}
const { compact = false, showEmail = true, submitLabel = 'Αποστολή' } = Astro.props;
---
<form class:list={["contact-form", compact && "compact"]} action="/api/contact" method="POST" data-contact-form>
  <div class="field">
    <label for="cf-name">Ονοματεπώνυμο *</label>
    <input id="cf-name" name="name" type="text" required autocomplete="name" />
  </div>
  <div class="field">
    <label for="cf-phone">Τηλέφωνο *</label>
    <input id="cf-phone" name="phone" type="tel" required autocomplete="tel" pattern="[0-9+\s\-()]{6,}" />
  </div>
  {showEmail && (
    <div class="field">
      <label for="cf-email">Email</label>
      <input id="cf-email" name="email" type="email" autocomplete="email" />
    </div>
  )}
  <div class="field">
    <label for="cf-message">Το μήνυμά σας</label>
    <textarea id="cf-message" name="message" rows={compact ? 3 : 5}></textarea>
  </div>
  <input type="text" name="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true" />
  <button type="submit" class="btn btn-accent">{submitLabel}</button>
  <p class="form-status" role="status" aria-live="polite"></p>
</form>

<style>
  .contact-form { display: grid; gap: 0.9rem; }
  .field { display: grid; gap: 0.35rem; }
  label { font-size: 0.85rem; font-weight: 500; color: var(--color-text); }
  input, textarea {
    font: inherit;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: #fff;
    color: var(--color-text);
    width: 100%;
  }
  input:focus, textarea:focus { outline: 2px solid var(--color-primary); outline-offset: 1px; border-color: var(--color-primary); }
  textarea { resize: vertical; }
  .form-status { min-height: 1.25em; margin: 0; font-size: 0.9rem; }
  .form-status.ok { color: #1a7f37; }
  .form-status.err { color: #cc2b2b; }
  .compact input, .compact textarea { padding: 0.6rem 0.75rem; }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.querySelector<HTMLParagraphElement>('.form-status');
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!status || !btn) return;
      status.textContent = 'Αποστολή…';
      status.className = 'form-status';
      btn.disabled = true;
      try {
        const data = Object.fromEntries(new FormData(form).entries());
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok) {
          form.reset();
          status.textContent = 'Ευχαριστούμε! Λάβαμε το μήνυμά σας και θα επικοινωνήσουμε σύντομα.';
          status.className = 'form-status ok';
        } else {
          status.textContent = json.error || 'Παρουσιάστηκε σφάλμα. Δοκιμάστε ξανά ή καλέστε μας.';
          status.className = 'form-status err';
        }
      } catch {
        status.textContent = 'Πρόβλημα σύνδεσης. Δοκιμάστε ξανά.';
        status.className = 'form-status err';
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
