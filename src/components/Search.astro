---
---
<div id="search" class="search-widget">
  <button type="button" class="search-trigger" aria-label="Αναζήτηση" data-search-open>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
  </button>
  <div class="search-modal" data-search-modal hidden>
    <div class="search-inner">
      <button type="button" class="search-close" aria-label="Κλείσιμο" data-search-close>&times;</button>
      <div id="pagefind-container"></div>
    </div>
  </div>
</div>

<style>
  .search-trigger { background: none; border: 0; padding: 0.5rem; cursor: pointer; color: var(--color-primary); }
  .search-trigger:hover { color: var(--color-accent-2); }
  .search-modal { position: fixed; inset: 0; background: rgba(16,50,124,0.8); z-index: 200; display: flex; align-items: flex-start; justify-content: center; padding: 5vh 1rem; }
  .search-modal[hidden] { display: none; }
  .search-inner { background: #fff; border-radius: var(--radius); padding: 2rem; max-width: 700px; width: 100%; max-height: 85vh; overflow: auto; position: relative; }
  .search-close { position: absolute; top: 0.5rem; right: 0.75rem; background: none; border: 0; font-size: 2rem; line-height: 1; cursor: pointer; color: var(--color-text); }
</style>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.querySelector('[data-search-modal]');
    const container = document.getElementById('pagefind-container');
    let ui;
    const init = () => {
      if (ui || !container || !window.PagefindUI) return;
      ui = new window.PagefindUI({ element: container, showSubResults: true, resetStyles: false });
    };
    document.querySelectorAll('[data-search-open]').forEach((b) => b.addEventListener('click', () => {
      init();
      modal.hidden = false;
      setTimeout(() => modal.querySelector('input')?.focus(), 50);
    }));
    document.querySelectorAll('[data-search-close]').forEach((b) => b.addEventListener('click', () => { modal.hidden = true; }));
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.hidden = true; });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') modal.hidden = true; });
  });
</script>
