          <line x1="12" y1="11.5" x2="12" y2="13.5"/>
          <line x1="12" y1="16.5" x2="12" y2="18.5"/>`,
  athlete: `<circle cx="12" cy="4" r="2"/>
            <path d="M12 6v6"/>
            <path d="M8 8h8"/>
            <path d="M10 15l-2 6"/>
            <path d="M14 15l2 6"/>
            <path d="M9 15h6"/>`,
  home: `<path d="M3 10l9-8 9 8v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
         <polyline points="9 21 9 12 15 12 15 21"/>`,
  hands: `<path d="M5 10v8a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-8"/>
          <path d="M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v3H9z"/>
          <circle cx="7" cy="16" r="1"/>
          <circle cx="17" cy="16" r="1"/>`,
  needle: `<line x1="12" y1="2" x2="12" y2="20"/>
           <path d="M8 8l8 8"/>
           <path d="M16 8l-8 8"/>
           <circle cx="12" cy="12" r="1" fill="currentColor"/>`,
  device: `<rect x="5" y="3" width="14" height="14" rx="2"/>
           <path d="M9 21h6"/>
           <path d="M12 17v4"/>`,
  wave: `<path d="M3 12c0-1 1-3 2-3s1 2 3 2 2-2 3-2 2 2 4 2 2-2 3-2 3 2 3 3"/>
         <path d="M3 18c0-1 1-3 2-3s1 2 3 2 2-2 3-2 2 2 4 2 2-2 3-2 3 2 3 3"/>`,
  target: `<circle cx="12" cy="12" r="10"/>
           <circle cx="12" cy="12" r="6"/>
           <circle cx="12" cy="12" r="2" fill="currentColor"/>`,
  movement: `<circle cx="12" cy="4" r="2"/>
             <path d="M12 6v6"/>
