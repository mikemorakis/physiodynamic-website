---
// Import actual Heroicons from the heroicons package
import adjustmentsVerticalIcon from 'heroicons/24/outline/adjustments-vertical.svg?raw';
import fireIcon from 'heroicons/24/outline/fire.svg?raw';
import homeModernIcon from 'heroicons/24/outline/home-modern.svg?raw';
import handThumbUpIcon from 'heroicons/24/outline/hand-thumb-up.svg?raw';
import sparklesIcon from 'heroicons/24/outline/sparkles.svg?raw';
import boltIcon from 'heroicons/24/outline/bolt.svg?raw';
import exclamationCircleIcon from 'heroicons/24/outline/exclamation-circle.svg?raw';
import mapPinIcon from 'heroicons/24/outline/map-pin.svg?raw';
import pencilSquareIcon from 'heroicons/24/outline/pencil-square.svg?raw';
import heartIcon from 'heroicons/24/outline/heart.svg?raw';
import shieldCheckIcon from 'heroicons/24/outline/shield-check.svg?raw';
import square2StackIcon from 'heroicons/24/outline/square-2-stack.svg?raw';
import circleStackIcon from 'heroicons/24/outline/circle-stack.svg?raw';
import wrenchIcon from 'heroicons/24/outline/wrench.svg?raw';
import cpuChipIcon from 'heroicons/24/outline/cpu-chip.svg?raw';

interface Props {
  type: string;
}

const { type } = Astro.props;

const iconMap: Record<string, string> = {
  'adjustments-vertical': adjustmentsVerticalIcon,
  'fire': fireIcon,
  'home-modern': homeModernIcon,
  'hand-thumb-up': handThumbUpIcon,
  'sparkles': sparklesIcon,
  'bolt': boltIcon,
  'exclamation-circle': exclamationCircleIcon,
  'map-pin': mapPinIcon,
  'pencil-square': pencilSquareIcon,
  'heart': heartIcon,
  'shield-check': shieldCheckIcon,
  'square-2-stack': square2StackIcon,
  'circle-stack': circleStackIcon,
  'wrench': wrenchIcon,
  'cpu-chip': cpuChipIcon,
};

const svgContent = iconMap[type] || iconMap['bolt'];
---

<Fragment set:html={svgContent} />

<style>
  :global(svg) {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }
</style>
