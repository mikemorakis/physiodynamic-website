---
// Import actual Heroicons from the heroicons package
import spineIcon from 'heroicons/24/outline/rectangle-stack.svg?raw';
import athleteIcon from 'heroicons/24/outline/user.svg?raw';
import homeIcon from 'heroicons/24/outline/home.svg?raw';
import handsIcon from 'heroicons/24/outline/hand-raised.svg?raw';
import needleIcon from 'heroicons/24/outline/beaker.svg?raw';
import deviceIcon from 'heroicons/24/outline/computer-desktop.svg?raw';
import waveIcon from 'heroicons/24/outline/bolt.svg?raw';
import targetIcon from 'heroicons/24/outline/star.svg?raw';
import movementIcon from 'heroicons/24/outline/arrow-trending-up.svg?raw';

interface Props {
  type: string;
}

const { type } = Astro.props;

const iconMap: Record<string, string> = {
  spine: spineIcon,
  athlete: athleteIcon,
  home: homeIcon,
  hands: handsIcon,
  needle: needleIcon,
  device: deviceIcon,
  wave: waveIcon,
  target: targetIcon,
  movement: movementIcon,
};

const svgContent = iconMap[type] || iconMap.device;
---

<Fragment set:html={svgContent} />

<style>
  :global(svg) {
    width: 100%;
    height: 100%;
    stroke: currentColor;
  }
</style>
