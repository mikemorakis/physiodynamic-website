---
import mckenzieIcon from '../../public/icons/physio/mckenzie.svg?raw';
import athleteIcon from '../../public/icons/physio/athlete.svg?raw';
import homeIcon from '../../public/icons/physio/home.svg?raw';
import handsIcon from '../../public/icons/physio/hands.svg?raw';
import acupunctureIcon from '../../public/icons/physio/acupuncture.svg?raw';
import energyIcon from '../../public/icons/physio/energy.svg?raw';
import wavesIcon from '../../public/icons/physio/waves.svg?raw';
import triggerIcon from '../../public/icons/physio/trigger.svg?raw';
import needleIcon from '../../public/icons/physio/needle.svg?raw';
import exerciseIcon from '../../public/icons/physio/exercise.svg?raw';
import shieldIcon from '../../public/icons/physio/shield.svg?raw';
import tapeIcon from '../../public/icons/physio/tape.svg?raw';
import pilatesIcon from '../../public/icons/physio/pilates.svg?raw';
import footIcon from '../../public/icons/physio/foot.svg?raw';
import magnetIcon from '../../public/icons/physio/magnet.svg?raw';

interface Props {
  type: string;
}

const { type } = Astro.props;

const iconMap: Record<string, string> = {
  'adjustments-vertical': mckenzieIcon,
  'fire': athleteIcon,
  'home-modern': homeIcon,
  'hand-thumb-up': handsIcon,
  'sparkles': acupunctureIcon,
  'bolt': energyIcon,
  'exclamation-circle': wavesIcon,
  'map-pin': triggerIcon,
  'pencil-square': needleIcon,
  'heart': exerciseIcon,
  'shield-check': shieldIcon,
  'square-2-stack': tapeIcon,
  'circle-stack': pilatesIcon,
  'wrench': footIcon,
  'cpu-chip': magnetIcon,
};

const svgContent = iconMap[type] || iconMap['bolt'];
---

<Fragment set:html={svgContent} />

<style>
  :global(svg) {
    width: 100%;
    height: 100%;
    color: var(--color-primary);
  }
</style>
