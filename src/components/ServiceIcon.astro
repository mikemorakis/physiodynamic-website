---
// Service icons — Flaticon "Physiotherapy" packs (lineal style).
// Icons by Magnific & Umeicon from www.flaticon.com (free license with attribution — see footer credit).
// PNGs live in /public/icons/physio/ and are tinted via CSS mask so they follow --color-primary.
interface Props {
  type: string;
}

const { type } = Astro.props;

const iconMap: Record<string, string> = {
  'adjustments-vertical': 'mckenzie',    // Flaticon 414332 — spine (McKenzie)
  'fire': 'athlete',                     // Flaticon 469451 — knee joint injury
  'home-modern': 'home',                 // Flaticon 6454118 — home care
  'hand-thumb-up': 'hands',              // Flaticon 414336 — hand (manual therapy)
  'sparkles': 'acupuncture',             // Flaticon 414359 — acupuncture needles
  'bolt': 'energy',                      // Flaticon 469462 — radiofrequency device (Indiba)
  'exclamation-circle': 'waves',         // Flaticon 414329 — shockwave/ultrasound
  'map-pin': 'trigger',                  // Flaticon 414358 — massage ball (trigger points)
  'pencil-square': 'needle',             // Flaticon 414319 — dry needling
  'heart': 'exercise',                   // Flaticon 414342 — dumbbells
  'shield-check': 'shield',              // Flaticon 414317 — assisted walking (Otago)
  'square-2-stack': 'tape',              // Flaticon 8281249 — kinesio tape roll
  'circle-stack': 'pilates',             // Flaticon 414322 — exercise ball
  'wrench': 'foot',                      // Flaticon 414360 — insoles
  'cpu-chip': 'magnet',                  // Flaticon 414361 — electrotherapy device (FMS)
};

const name = iconMap[type] || iconMap['bolt'];
const src = `/icons/physio/${name}.png`;
---

<span class="physio-icon" style={`--icon-url: url('${src}')`} role="img" aria-hidden="true"></span>

<style>
  .physio-icon {
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--color-primary);
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: 62%;
    mask-size: 62%;
  }
</style>
