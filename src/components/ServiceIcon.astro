---
interface Props {
  type: string;
}

const { type } = Astro.props;

const iconMap: Record<string, string> = {
  'adjustments-vertical': '/icons/physio/mckenzie.svg',
  'fire': '/icons/physio/athlete.svg',
  'home-modern': '/icons/physio/home.svg',
  'hand-thumb-up': '/icons/physio/hands.svg',
  'sparkles': '/icons/physio/acupuncture.svg',
  'bolt': '/icons/physio/energy.svg',
  'exclamation-circle': '/icons/physio/waves.svg',
  'map-pin': '/icons/physio/trigger.svg',
  'pencil-square': '/icons/physio/needle.svg',
  'heart': '/icons/physio/exercise.svg',
  'shield-check': '/icons/physio/shield.svg',
  'square-2-stack': '/icons/physio/tape.svg',
  'circle-stack': '/icons/physio/pilates.svg',
  'wrench': '/icons/physio/foot.svg',
  'cpu-chip': '/icons/physio/magnet.svg',
};

const iconPath = iconMap[type] || iconMap['bolt'];
---

<img src={iconPath} alt="Service icon" class="service-icon-img" />

<style>
  .service-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    color: var(--color-primary);
  }
</style>
