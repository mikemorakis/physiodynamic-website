---
import { Icon } from 'astro-icon/components';

interface Props {
  type: string;
}

const { type } = Astro.props;

const iconMap: Record<string, string> = {
  spine: 'heroicons:spine',
  athlete: 'heroicons:user-running',
  home: 'heroicons:home',
  hands: 'heroicons:hand-raised',
  needle: 'heroicons:beaker',
  device: 'heroicons:computer-desktop',
  wave: 'heroicons:bolt',
  target: 'heroicons:target',
  movement: 'heroicons:arrow-trending-up',
};

const iconName = iconMap[type] || iconMap.device;
---

<Icon name={iconName} />

<style>
  :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
