---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';
import { heroServices, faqs, testimonials, partners, about, philosophy, servicesIntro, why } from '../data/home';
---
<BaseLayout
  title="Σύγχρονο κέντρο φυσικοθεραπείας στο Π. Φάληρο"
  description="Physio Dynamic — σύγχρονο κέντρο φυσικοθεραπείας στο Παλαιό Φάληρο. McKenzie, Manual Therapy, Βελονισμός, Shockwave, Pilates, ορθωτικά πέλματα. Καλέστε 211 750 6000."
>
  <script is:inline>
    // Belt-and-suspenders: some browsers refuse to autoplay until the muted flag
    // is set from JS AND a play() call is attempted. Also retry play on first
    // user interaction if the browser blocked autoplay entirely.
    (function () {
      const v = document.querySelector('[data-hero-video]');
      if (!v) return;
      v.muted = true;
      const tryPlay = () => v.play().catch(() => {});
      tryPlay();
      ['pointerdown', 'touchstart', 'keydown', 'scroll'].forEach((ev) => {
        window.addEventListener(ev, function once() {
          tryPlay();
          window.removeEventListener(ev, once);
        }, { once: true, passive: true });
      });
    })();
  </script>

  <!-- HERO -->
  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/wp-content/uploads/2022/04/GIO_7728.jpg"
      disablepictureinpicture
      disableremoteplayback
      data-hero-video
    >
      <source src="/hero.mp4" type="video/mp4" />
      <img src="https://physiodynamic.com.gr/wp-content/uploads/2022/04/physiodynamics.jpg" alt="" class="hero-video-fallback" />
    </video>
    <img class="hero-fallback-img" src="https://physiodynamic.com.gr/wp-content/uploads/2022/04/physiodynamics.jpg" alt="" aria-hidden="true" />
    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="wrap hero-inner">
      <p class="hero-eyebrow">Φυσικοθεραπεία στο Παλαιό Φάληρο</p>
      <h1 class="hero-title">Εξατομικευμένη φυσικοθεραπεία για γρήγορη και ασφαλή αποκατάσταση</h1>

      <p class="hero-lede">Σύγχρονες θεραπείες, θεραπευτική άσκηση και προσωπική καθοδήγηση από εξειδικευμένους φυσικοθεραπευτές.</p>

      <div class="hero-ctas">
        <a href={site.bookingUrl} target="_blank" rel="noopener" class="hero-cta-primary">Κλείστε Ραντεβού</a>
        <a href={`tel:00302117506000`} class="hero-cta-secondary">Καλέστε μας: 211 750 6000</a>
      </div>

      <ul class="hero-trust">
        <li>Συμβεβλημένοι με όλα τα ταμεία</li>
        <li>Άμεση εξυπηρέτηση</li>
        <li>Σύγχρονος εξοπλισμός</li>
      </ul>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section about-section">
    <div class="wrap about-grid">
      <div class="about-media">
        <figure class="about-photo-main">
          <img src="/wp-content/uploads/2022/04/GIO_7447.jpg" alt="Physio Dynamic — Θεραπεία στο κέντρο" loading="lazy" />
        </figure>
        <figure class="about-photo-inset">
          <img src="/wp-content/uploads/2022/04/GIO_7737.jpg" alt="Θεραπευτική άσκηση" loading="lazy" />
        </figure>
      </div>

      <div class="about-content">
        <h2>{about.subheading}</h2>
        <p><strong>{about.paragraphs[0].split('.')[0]}.</strong>{about.paragraphs[0].slice(about.paragraphs[0].indexOf('.') + 1)}</p>
        <p>{about.paragraphs[1]}</p>

        <div class="about-info">
          <div class="about-info-block">
            <h3>Ωράριο</h3>
            <p>Καθημερινές 09:00 – 21:00</p>
          </div>
          <div class="about-info-block">
            <h3>Διεύθυνση</h3>
            <p>{site.addressLine}</p>
          </div>
          <div class="about-info-block">
            <h3>Επικοινωνία</h3>
            <p>
              <a href={`tel:00302117506000`}>{site.phones[0]}</a>, <a href={`tel:00306936579008`}>{site.phones[1]}</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PATIENT-CENTERED -->
  <section class="section patient-band">
    <div class="patient-bg" aria-hidden="true"></div>
    <div class="wrap text-center patient-content">
      <p class="eyebrow">Η φιλοσοφία μας</p>
      <h2>{philosophy.heading}</h2>
      <p class="lede-2">{philosophy.paragraph}</p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section">
    <div class="wrap">
      <div class="text-center" style="margin-bottom:2.5rem;">
        <p class="eyebrow">Υπηρεσίες</p>
        <h2>Υπηρεσίες Φυσικοθεραπείας</h2>
        <p class="lede-2">{servicesIntro}</p>
      </div>
      <div class="grid grid-3">
        {heroServices.map((s) => (
          <a href={`/${s.slug}/`} class="service-card">
            <div class="service-image">
              <img src={s.image} alt={s.title} loading="lazy" />
            </div>
            <div class="service-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="1" fill="currentColor"/><path d="M12 8v8M8 12h8"/>
              </svg>
            </div>
            <div class="service-content">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
              <ul class="service-benefits">
                {s.benefits.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
              <span class="service-link">Μάθετε περισσότερα <span class="arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="wrap faq-wrap">
      <div class="text-center" style="margin-bottom:2rem;">
        <p class="eyebrow">FAQ</p>
        <h2>Συχνές Ερωτήσεις</h2>
      </div>
      <div class="faq-list">
        {faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q}</summary>
            <div class="answer">
              {f.a.split('\n\n').map((para) => <p>{para}</p>)}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section">
    <div class="wrap">
      <div class="text-center" style="margin-bottom:2rem;">
        <p class="eyebrow">Αξιολογήσεις</p>
        <h2>Τι λένε οι ασθενείς μας</h2>
      </div>
      <div class="grid grid-3">
        {testimonials.map((t) => (
          <blockquote class="card testimonial">
            <p>&ldquo;{t.text}&rdquo;</p>
            <cite>— {t.name}</cite>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="section section-alt">
    <div class="wrap text-center">
      <p class="eyebrow">Δίκτυο</p>
      <h2>Συνεργασίες</h2>
      <ul class="partners">
        {partners.map((p) => (
          <li>
            {p.image && <img src={p.image} alt={p.name} loading="lazy" />}
            <span>{p.name}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- WHY -->
  <section class="section why-band">
    <div class="wrap">
      <div class="why-grid">
        <div>
          <p class="eyebrow">Γιατί εμάς</p>
          <h2>{why.heading}</h2>
        </div>
        <div>
          <p>{why.paragraph}</p>
          <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-accent">Κλείστε ραντεβού</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-band">
    <div class="wrap contact-grid">
      <div>
        <p class="eyebrow">Καλέστε μας</p>
        <h2>Μη διστάσετε να επικοινωνήσετε μαζί μας</h2>
        <p>Χρησιμοποιώντας αυτήν την φόρμα μπορείτε να μας στείλετε τις ερωτήσεις σας, να ζητήσετε να επικοινωνήσουμε μαζί σας ή απλά να μας πείτε τι σας απασχολεί. Είμαστε έτοιμοι να σας ακούσουμε!</p>
        <ul class="contact-info">
          <li><strong>Τηλέφωνο:</strong> <a href={`tel:00302117506000`}>{site.phones[0]}</a>, <a href={`tel:00306936579008`}>{site.phones[1]}</a></li>
          <li><strong>Διεύθυνση:</strong> {site.addressLine}</li>
        </ul>
      </div>
      <div class="card">
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    color: #fff;
    padding: 6rem 0 7rem;
    min-height: 640px;
    display: flex;
    align-items: center;
    background: var(--color-primary-dark);
    isolation: isolate;
    overflow: hidden;
    text-align: center;
  }

  /* Fallback still image: shown when the video is loading, when autoplay is blocked,
     when the browser can't decode the video, or when the network request fails.
     Sits at the very bottom of the stack. */
  .hero-fallback-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    animation: heroZoom 20s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes heroZoom {
    from { transform: scale(1); }
    to   { transform: scale(1.10); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-fallback-img { animation: none; }
  }

  /* Video sits above the fallback image so it hides it when it starts playing. */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
    background: transparent;
  }
  .hero-video-fallback { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(135deg, rgba(0, 8, 127, 0.45) 0%, rgba(16, 50, 124, 0.40) 100%);
  }

  .hero-inner {
    max-width: 780px;
    margin: 0 auto;
    display: block;
    position: relative;
    z-index: 3;
  }

  .hero-eyebrow {
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.9rem;
    margin: 0 0 1.5rem;
  }

  .hero-title {
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.2;
    text-transform: none;
    letter-spacing: -0.005em;
    margin: 0 0 2rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.25);
  }

  .hero-divider {
    width: 60px;
    height: 2px;
    background: rgba(255, 255, 255, 0.5);
    border: 0;
    margin: 0 auto 2rem;
  }

  .hero-lede {
    color: rgba(255, 255, 255, 0.88);
    max-width: 600px;
    margin: 0 auto 2.25rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin: 2rem 0 3rem;
    flex-wrap: wrap;
  }

  .hero-cta-primary {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-primary-dark);
    padding: 1.2rem 2.8rem;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-weight: 600;
    text-transform: none;
    font-size: 0.95rem;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 8px 25px rgba(167, 240, 0, 0.35);
    transition: all 0.2s;
    line-height: 1.4;
  }
  .hero-cta-primary:hover { background: var(--color-accent-2); transform: translateY(-2px); box-shadow: 0 12px 35px rgba(167, 240, 0, 0.45); }

  .hero-cta-secondary {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-weight: 600;
    text-transform: none;
    font-size: 0.95rem;
    text-decoration: none;
    cursor: pointer;
    border: 2px solid rgba(255, 255, 255, 0.3);
    transition: all 0.2s;
  }
  .hero-cta-secondary:hover { background: rgba(255, 255, 255, 0.25); border-color: #fff; }

  .hero-trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.9);
  }
  .hero-trust li { display: flex; align-items: center; gap: 0.5rem; }
  .hero-trust li::before { content: '✓'; color: var(--color-accent); font-weight: 700; }

  @media (max-width: 700px) {
    .hero { padding: 4.5rem 0 5rem; min-height: 0; }
    .hero-row { grid-template-columns: 1fr; }
    .hero-cta { padding: 1rem 1.5rem; font-size: 0.9rem; width: 100%; }
  }

  .about-section { padding: 5rem 0; }
  .about-grid { display: grid; grid-template-columns: 1fr 1.05fr; gap: 4rem; align-items: center; }

  /* Photo collage — main portrait with a smaller lime-bordered inset overlapping bottom-right */
  .about-media { position: relative; padding: 0 3.5rem 3rem 0; }
  .about-photo-main { margin: 0; }
  .about-photo-main img {
    width: 100%;
    border-radius: 14px;
    box-shadow: 0 20px 50px rgba(16, 50, 124, 0.18);
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  .about-photo-inset {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 55%;
    max-width: 260px;
    margin: 0;
  }
  .about-photo-inset img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    border: 6px solid var(--color-accent);
    border-radius: 8px;
    box-shadow: 0 15px 35px rgba(16, 50, 124, 0.25);
    background: #fff;
  }

  .about-content h2 {
    color: var(--color-primary);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    text-transform: none;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    line-height: 1.15;
  }
  .about-content > p {
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1rem;
    color: var(--color-text);
  }
  .about-content > p strong { color: var(--color-primary); font-weight: 700; }

  .about-info { margin-top: 2rem; display: grid; gap: 1.25rem; }
  .about-info-block h3 {
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: 1rem;
    margin: 0 0 0.15rem;
    text-transform: none;
    letter-spacing: 0;
  }
  .about-info-block p { margin: 0; color: var(--color-text); }
  .about-info-block p a { color: var(--color-text); text-decoration: none; }
  .about-info-block p a:hover { color: var(--color-primary); }

  @media (max-width: 800px) {
    .about-section { padding: 3rem 0; }
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-media { padding: 0 2rem 2rem 0; max-width: 480px; margin: 0 auto; }
    .about-photo-inset { width: 50%; }
  }

  .patient-band { position: relative; color: #fff; padding: 5rem 0; isolation: isolate; overflow: hidden; }
  .patient-bg { position: absolute; inset: 0; z-index: -1;
    background-image: linear-gradient(135deg, rgba(16,50,124,0.88) 0%, rgba(0,8,127,0.8) 100%), url('/wp-content/uploads/2022/04/GIO_7364-1.jpg');
    background-size: cover;
    background-position: center;
  }
  .patient-band h2 { color: #fff; }
  .patient-band .eyebrow { color: var(--color-accent); }
  .patient-content { position: relative; }
  .lede-2 { max-width: 720px; margin: 0 auto; font-size: 1.1rem; }

  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    padding: 0;
    overflow: visible;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
    padding-top: 30px;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(16, 50, 124, 0.12);
  }
  .service-image {
    margin: 0;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-bg-alt);
    border-radius: 12px 12px 0 0;
  }
  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .service-card:hover .service-image img {
    transform: scale(1.06);
  }
  .service-icon {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    width: 70px;
    height: 70px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    z-index: 20;
    box-shadow: 0 6px 16px rgba(16, 50, 124, 0.25);
    flex-shrink: 0;
  }
  .service-icon svg {
    width: 38px;
    height: 38px;
    stroke-width: 1.5;
  }
  .service-content {
    padding: 2.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .service-card h3 {
    color: var(--color-primary);
    font-size: 1.15rem;
    font-family: var(--font-heading);
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    line-height: 1.3;
    text-align: center;
    text-transform: none !important;
  }
  .service-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 1.25rem 0;
    text-align: left;
  }
  .service-benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .service-benefits li {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .service-benefits li::before {
    content: '✓';
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .service-link {
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: none;
    font-size: 0.85rem;
    margin-top: auto;
    display: inline-block;
    transition: all 0.3s ease;
  }
  .service-link .arrow {
    display: inline-block;
    margin-left: 0.3rem;
    transition: transform 0.3s ease;
  }
  .service-card:hover .service-link .arrow {
    transform: translateX(4px);
  }

  .faq-wrap { max-width: 820px; }
  .faq-list details { background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius); margin-bottom: 0.75rem; overflow: hidden; }
  .faq-list summary { padding: 1rem 1.25rem; cursor: pointer; font-family: var(--font-heading); font-weight: 700; text-transform: uppercase; font-size: 0.95rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-list summary::after { content: '+'; font-size: 1.5rem; color: var(--color-primary); }
  .faq-list details[open] summary::after { content: '−'; }
  .answer { padding: 0 1.25rem 1rem; color: var(--color-text-muted); }

  .testimonial { background: var(--color-bg-alt); border: 0; font-style: italic; }
  .testimonial cite { display: block; margin-top: 1rem; font-style: normal; font-weight: 700; color: var(--color-primary); }

  .partners { list-style: none; padding: 0; margin: 2rem auto 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; max-width: 960px; }
  .partners li { background: #fff; padding: 1.25rem; border-radius: var(--radius); border-left: 3px solid var(--color-accent-2); display: flex; flex-direction: column; align-items: center; gap: 0.75rem; text-align: center; }
  .partners li img { max-width: 100%; max-height: 80px; width: auto; object-fit: contain; }
  .partners li span { font-size: 0.9rem; color: var(--color-text); font-weight: 500; }
  .form-intro { font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.75rem; }

  .why-band { background: var(--color-primary); color: #fff; }
  .why-band h2 { color: var(--color-accent); }
  .why-band .eyebrow { color: var(--color-accent); }
  .why-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; align-items: center; }
  @media (max-width: 800px) { .why-grid { grid-template-columns: 1fr; } }

  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  .contact-info { list-style: none; padding: 0; margin: 1.5rem 0 0; }
  .contact-info li { margin-bottom: 0.5rem; }
  @media (max-width: 800px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
