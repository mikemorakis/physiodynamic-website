---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout title="Ευχαριστούμε" description="Το μήνυμά σας παραλήφθηκε.">
  <section class="thanks">
    <div class="wrap text-center">
      <p class="eyebrow">Λάβαμε το μήνυμά σας</p>
      <h1>Ευχαριστούμε!</h1>
      <p class="lede">Θα επικοινωνήσουμε μαζί σας το συντομότερο δυνατό.</p>
      <p>Αν είναι επείγον, μπορείτε να μας καλέσετε άμεσα:</p>
      <div class="cta">
        <a href={`tel:00302117506000`} class="btn btn-accent">Καλέστε {site.phoneDisplay}</a>
        <a href="/" class="btn">Επιστροφή στην αρχική</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks { min-height: 60vh; display: flex; align-items: center; padding: 4rem 0; }
  .lede { font-size: 1.2rem; max-width: 560px; margin: 0 auto 1.5rem; }
  .cta { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }
</style>
