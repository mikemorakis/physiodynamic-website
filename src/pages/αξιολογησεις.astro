---
import BaseLayout from '../layouts/BaseLayout.astro';
import { testimonials } from '../data/home';
---

<BaseLayout
  title="Αξιολογήσεις - Physio Dynamic"
  description="Διαβάστε τι λένε οι ασθενείς μας για τις υπηρεσίες φυσικοθεραπείας του Physio Dynamic"
>
  <section class="section">
    <div class="wrap">
      <div class="text-center" style="margin-bottom:3rem;">
        <h1>Αξιολογήσεις από τους Ασθενείς μας</h1>
        <p class="lede-2" style="max-width: 700px; margin: 1rem auto 0;">Διαβάστε τι λένε οι ασθενείς μας σχετικά με την εμπειρία τους στο Physio Dynamic</p>
      </div>

      <div class="reviews-grid">
        {testimonials.map((t) => (
          <div class="review-card">
            <div class="review-stars">
              {Array.from({length: t.rating}).map(() => <span>★</span>)}
            </div>
            <p class="review-text">&ldquo;{t.text}&rdquo;</p>
            <p class="review-author">{t.name}</p>
          </div>
        ))}
      </div>

      <div class="reviews-stats">
        <div class="stat">
          <div class="stat-number">5.0</div>
          <div class="stat-label">Μέσος Όρος Αξιολόγησης</div>
        </div>
        <div class="stat">
          <div class="stat-number">{testimonials.length}</div>
          <div class="stat-label">Αξιολογήσεις</div>
        </div>
        <div class="stat">
          <div class="stat-number">100%</div>
          <div class="stat-label">5 Αστέρων</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="wrap">
      <div class="text-center">
        <h2>Έχετε ήδη επισκεφτεί μας;</h2>
        <p class="lede-2" style="max-width: 600px; margin: 1rem auto 0;">Μοιραστείτε την εμπειρία σας με άλλους ασθενείς</p>
        <a href="https://g.page/physio-dynamic/review" target="_blank" class="btn btn-accent" style="margin-top: 1.5rem;">Αφήστε Αξιολόγηση στο Google</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .review-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .review-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(16, 50, 124, 0.08);
  }

  .review-stars {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .review-stars span {
    color: var(--color-accent);
    font-size: 1.15rem;
  }

  .review-text {
    flex: 1;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
    font-style: italic;
  }

  .review-author {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.9rem;
    margin: 0;
    font-style: normal;
  }

  .reviews-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    margin-top: 4rem;
  }

  .stat {
    padding: 1rem 0;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 800px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .reviews-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
