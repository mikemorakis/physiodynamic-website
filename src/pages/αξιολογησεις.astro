---
import BaseLayout from '../layouts/BaseLayout.astro';
import { testimonials } from '../data/home';
---

<BaseLayout
  title="Αξιολογήσεις - Physio Dynamic"
  description="Διαβάστε τι λένε οι ασθενείς μας για τις υπηρεσίες φυσικοθεραπείας του Physio Dynamic"
>
  <section class="section">
    <div class="wrap">
      <div class="text-center" style="margin-bottom:3rem;">
        <h1>Αξιολογήσεις από τους Ασθενείς μας</h1>
        <p class="lede-2" style="max-width: 700px; margin: 1rem auto 0;">Διαβάστε τι λένε οι ασθενείς μας σχετικά με την εμπειρία τους στο Physio Dynamic</p>
      </div>

      <div class="reviews-grid">
        {testimonials.map((t) => (
          <div class="review-card">
            <div class="review-header">
              <div class="review-stars">
                {Array.from({length: t.rating}).map(() => <span>★</span>)}
              </div>
              <a href="https://g.page/physio-dynamic/review" target="_blank" class="google-link" title="View on Google">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12.545 10.239v3.821h5.445c-0.712 2.315-2.647 3.972-5.445 3.972-3.332 0-6.033-2.701-6.033-6.032 0-3.331 2.701-6.032 6.032-6.032 1.498 0 2.866 0.549 3.921 1.453l2.814-2.814c-1.733-1.605-4.069-2.586-6.735-2.586-5.531 0-10.016 4.485-10.016 10.016s4.485 10.016 10.016 10.016c5.531 0 10.016-4.485 10.016-10.016 0-0.677-0.074-1.338-0.213-1.975h-9.803z"/></svg>
              </a>
            </div>
            <p class="review-text">&ldquo;{t.text}&rdquo;</p>
            <p class="review-author">{t.name}</p>
          </div>
        ))}
      </div>

      <div class="reviews-stats">
        <div class="stat">
          <div class="stat-number">5.0</div>
          <div class="stat-label">Μέσος Όρος Αξιολόγησης</div>
        </div>
        <div class="stat">
          <div class="stat-number">{testimonials.length}</div>
          <div class="stat-label">Αξιολογήσεις</div>
        </div>
        <div class="stat">
          <div class="stat-number">100%</div>
          <div class="stat-label">5 Αστέρων</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="wrap">
      <div class="text-center">
        <h2>Δείτε όλες τις αξιολογήσεις στο Google</h2>
        <p class="lede-2" style="max-width: 600px; margin: 1rem auto 0;">Περισσότερες αξιολογήσεις και λεπτομέρειες διαθέσιμες στο Google Business Profile</p>
        <a href="https://g.page/physio-dynamic" target="_blank" class="btn btn-accent" style="margin-top: 1.5rem;">Δείτε στο Google Maps</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="text-center">
        <h2>Έχετε ήδη επισκεφτεί μας;</h2>
        <p class="lede-2" style="max-width: 600px; margin: 1rem auto 0;">Μοιραστείτε την εμπειρία σας με άλλους ασθενείς και βοηθήστε μας να βελτιωνόμαστε</p>
        <a href="https://g.page/physio-dynamic/review" target="_blank" class="btn btn-accent" style="margin-top: 1.5rem;">Αφήστε Αξιολόγηση στο Google</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .review-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }

  .review-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(16, 50, 124, 0.08);
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .google-link {
    color: var(--color-primary);
    opacity: 0.6;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .google-link:hover {
    opacity: 1;
  }

  .review-stars {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .review-stars span {
    color: var(--color-accent);
    font-size: 1.15rem;
  }

  .review-text {
    flex: 1;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.5rem 0;
    font-style: italic;
  }

  .review-author {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.9rem;
    margin: 0;
    font-style: normal;
  }

  .reviews-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    margin-top: 4rem;
  }

  .stat {
    padding: 1rem 0;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  @media (max-width: 800px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .reviews-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
